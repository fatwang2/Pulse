# Copy to .env.release and keep the real file out of git.

# Apple Developer ID signing and notarization.
DEVELOPMENT_TEAM=N99T75CSKK
APPLE_SIGNING_IDENTITY="Developer ID Application: WANG DING (N99T75CSKK)"
APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"
APPLE_API_KEY="XXXXXXXXXX"
APPLE_API_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"

# GitHub Releases target. Required because the Pulse repo may not have a git remote yet.
GH_REPO="owner/Pulse"

# Sparkle update feed. The release script maintains this asset on the stable
# `appcast` GitHub Release tag by default.
SPARKLE_FEED_URL="https://github.com/owner/Pulse/releases/download/appcast/appcast.xml"
SPARKLE_PUBLIC_ED_KEY=""

# Optional. If set, release-mac.sh imports the private EdDSA key before generating
# the appcast. Do not commit the private key.
# SPARKLE_PRIVATE_KEY_FILE="$HOME/.config/pulse/sparkle_private_key"

# Optional. Directory containing Sparkle's generate_appcast and generate_keys tools.
# SPARKLE_BIN="/path/to/Sparkle/bin"
